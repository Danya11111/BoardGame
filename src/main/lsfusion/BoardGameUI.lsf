// =============================================================================
// BoardGameUI.lsf — сценарии гостя, участника клуба и администратора
// =============================================================================

MODULE BoardGameUI;

REQUIRE BoardGameDomain, BoardGameLogic, BoardGameSecurity, BoardGameAuth, BoardGameExampleData, Utils, Security, Authentication;

NAMESPACE BoardGame;

// --- Тексты приветствия и главного экрана (только UX, без доменной логики) ---

welcomeHeadline ' ' () = 'Не знаете, во что поиграть на игротеке?' CHARWIDTH 72;

welcomeLead ' ' () =
    'Здесь каталог настолок вашего клуба: можно просто посмотреть, что на полках, или подобрать игру, похожую на ту, что вам уже зашла.' CHARWIDTH 92;

welcomeExample ' ' () =
    'Например, полюбилась Уно — найдите её в списке (или другое знакомое имя), и мы подскажем похожие варианты вроде «Свинтус» или «Лунаси», если они есть в базе клуба.' CHARWIDTH 92;

welcomeLibraryHint ' ' () =
    'Не обязано разбираться в жанрах и издателях: дальше подскажем по шагам. Чтобы продолжить, войдите или зарегистрируйтесь.' CHARWIDTH 92;

welcomeLoginHint ' ' () =
    'После «Войти» откроется «Главная»: там можно найти похожую игру по уже понравившейся или открыть библиотеку всех настолок клуба.' CHARWIDTH 92;

hubTitle ' ' () = 'С чего начнём?' CHARWIDTH 50;

hubSubtitle ' ' () = 'Оба пункта доступны в любой момент — выберите то, что сейчас ближе.' CHARWIDTH 85;

hubHintSimilar ' ' () =
    'Когда уже есть игра, которая зашла, и хочется «ещё такого же духа» из того, что есть у клуба.' CHARWIDTH 58;

hubHintLibrary ' ' () =
    'Когда хочется спокойно пролистать всё, что есть в клубе, и отфильтровать по игрокам, времени или наличию.' CHARWIDTH 58;

// Пошаговый сценарий «понравилась игра → похожие» без лишней терминологии.
similarFinderStep1 ' ' () =
    '1. Найдите игру, которая вам понравилась — чаще всего проще всего начать с названия.' CHARWIDTH 95;

similarFinderStep2 ' ' () =
    '2. Выберите в таблице одну строку с нужной игрой (щелчок по строке).' CHARWIDTH 95;

similarFinderStep3 ' ' () =
    '3. Нажмите «Показать похожие игры». Карточку с описанием можно открыть отдельно, если сначала нужны подробности.' CHARWIDTH 95;

similarFinderSearchHint ' ' () =
    'Совет: над таблицей есть фильтры — введите несколько букв из названия в поле названия игры, список сразу сузится. При желании можно отфильтровать по жанру или наличию.' CHARWIDTH 95;

// Библиотека: вводный блок без «табличного» тона (только тексты для формы).
gamesLibraryLead ' ' () =
    'Здесь собраны все настолки, которые есть в клубе. Листайте список или сузьте его под себя.' CHARWIDTH 95;

gamesLibrarySubLead ' ' () =
    'Выберите строку: можно открыть карточку с описанием или сразу посмотреть похожие игры — так же, как в сценарии «Найти похожую».' CHARWIDTH 95;

gamesLibraryFiltersHint ' ' () =
    'Фильтры над таблицей: название, жанр, наличие. Поле «Сколько играет человек» ниже сужает список под ваш состав (например 4). Пусто или 0 — снова все игры.' CHARWIDTH 95;

// --- Приветствие (гость) ---

FORM welcomeLanding 'Клуб настольных игр'
    PROPERTIES()
        READONLY welcomeHeadline PANEL, welcomeLead PANEL, welcomeExample PANEL, welcomeLibraryHint PANEL, welcomeLoginHint PANEL
    PROPERTIES()
        welcomeLogin 'Войти' = reloginLoginUser[],
        welcomeRegister 'Зарегистрироваться' = openClubRegistrationPage[]
;

DESIGN welcomeLanding {
    NEW welcomeCopy FIRST {
        horizontal = FALSE;
        fill = 1;
        MOVE PROPERTY(welcomeHeadline());
        MOVE PROPERTY(welcomeLead());
        MOVE PROPERTY(welcomeExample());
        MOVE PROPERTY(welcomeLibraryHint());
        MOVE PROPERTY(welcomeLoginHint());
    }
    NEW welcomeButtons {
        horizontal = TRUE;
        // Действия формы в DESIGN задаются без «()» (имя свойства формы, не вызов).
        MOVE PROPERTY(welcomeLogin);
        MOVE PROPERTY(welcomeRegister);
    }
}

// --- Рекомендации по выбранной игре ---

// Короткий контекст и сообщение при пустом топе (только подписи для формы, логика — в BoardGameLogic).
recommendationsContext (BoardGame g) =
    CONCAT 'Подобрали похожие варианты к игре «', name(g), '» из каталога клуба.' CHARWIDTH 110;

recommendationsEmptyHint (BoardGame g) =
    IF topRecommendedGame(g, 1) IS BoardGame THEN ''
    ELSE 'Подходящих игр в каталоге не нашлось — попробуйте другую игру или загляните в библиотеку.' CHARWIDTH 110;

FORM recommendationsForm 'Похожие игры'
    OBJECTS g = BoardGame PANEL
    PROPERTIES(g) READONLY recommendationsContext PANEL, recommendationsEmptyHint PANEL, name
    PROPERTIES
        rec1Name '1. Игра' = name(topRecommendedGame(g, 1)),
        rec1Score '1. Насколько близко (чем выше, тем ближе)' = topRecommendedScore(g, 1),
        rec1Facts '1. Игроки, время, возраст' = recommendationQuickFacts(g, 1),
        rec1Why '1. Почему похожа' = recommendationExplanationTrimmed(g, topRecommendedGame(g, 1)),
        rec2Name '2. Игра' = name(topRecommendedGame(g, 2)),
        rec2Score '2. Насколько близко (чем выше, тем ближе)' = topRecommendedScore(g, 2),
        rec2Facts '2. Игроки, время, возраст' = recommendationQuickFacts(g, 2),
        rec2Why '2. Почему похожа' = recommendationExplanationTrimmed(g, topRecommendedGame(g, 2)),
        rec3Name '3. Игра' = name(topRecommendedGame(g, 3)),
        rec3Score '3. Насколько близко (чем выше, тем ближе)' = topRecommendedScore(g, 3),
        rec3Facts '3. Игроки, время, возраст' = recommendationQuickFacts(g, 3),
        rec3Why '3. Почему похожа' = recommendationExplanationTrimmed(g, topRecommendedGame(g, 3))
;

DESIGN recommendationsForm {
    NEW recIntro FIRST {
        horizontal = FALSE;
        fill = 1;
        MOVE PROPERTY(recommendationsContext(g));
        MOVE PROPERTY(recommendationsEmptyHint(g));
    }
    NEW recSource {
        horizontal = FALSE;
        MOVE PROPERTY(name(g));
    }
    NEW recFirst {
        horizontal = FALSE;
        // Свойства блока PROPERTIES без OBJECT — это поля формы, в DESIGN без (g).
        MOVE PROPERTY(rec1Name);
        MOVE PROPERTY(rec1Score);
        MOVE PROPERTY(rec1Facts);
        MOVE PROPERTY(rec1Why);
    }
    NEW recSecond {
        horizontal = FALSE;
        MOVE PROPERTY(rec2Name);
        MOVE PROPERTY(rec2Score);
        MOVE PROPERTY(rec2Facts);
        MOVE PROPERTY(rec2Why);
    }
    NEW recThird {
        horizontal = FALSE;
        MOVE PROPERTY(rec3Name);
        MOVE PROPERTY(rec3Score);
        MOVE PROPERTY(rec3Facts);
        MOVE PROPERTY(rec3Why);
    }
}

getRecommendations 'Показать похожие игры' (BoardGame g) {
    printToLog(CONCAT ' ', 'Рекомендации для игры', name(g));
    FOR iterate(i, 1, 3) DO {
        IF topRecommendedGame(g, i) IS BoardGame THEN {
            printToLog(CONCAT ' ', '#', i, ':', name(topRecommendedGame(g, i)), 'балл=', topRecommendedScore(g, i));
        }
    }
    SHOW recommendationsForm OBJECTS g = g;
}

// --- Карточка игры ---

// Сначала то, что помогает решить «во что сесть за стол», затем описание и учётные поля клуба.
FORM gameDetail 'Карточка игры'
    OBJECTS g = BoardGame PANEL
    PROPERTIES(g) READONLY name, image, genre, playerRange, durationMinutes, minAge, isAvailable, description, publisher, owner
    PROPERTIES(g) NEWSESSION getRecommendations
;

// --- Администрирование: карточка игры (объявить до расширения gameDetail) ---

// Подсказка для формы редактирования: должна быть объявлена до DESIGN gameEdit.
gameEditOwnerHint ' ' () =
    'Владелец экземпляра — запись в справочнике клуба (чья физическая копия на полке), это не логин участника сайта.' CHARWIDTH 92;

FORM gameEdit 'Карточка игры (редактирование)'
    OBJECTS g = BoardGame PANEL
    PROPERTIES()
        READONLY gameEditOwnerHint PANEL
    PROPERTIES(g) name, description, genre, minPlayers, maxPlayers, durationMinutes, minAge, publisher, owner, available, image
    EDIT BoardGame OBJECT g
;

EXTEND FORM gameEdit
    OBJECTS m = Mechanic
    PROPERTIES(g, m) hasMechanic
;

DESIGN gameEdit {
    NEW geMain FIRST {
        horizontal = FALSE;
        fill = 1;
        MOVE PROPERTY(name(g));
        MOVE PROPERTY(description(g));
        MOVE PROPERTY(image(g));
    }
    NEW gePlay {
        horizontal = FALSE;
        MOVE PROPERTY(genre(g));
        MOVE PROPERTY(minPlayers(g));
        MOVE PROPERTY(maxPlayers(g));
        MOVE PROPERTY(durationMinutes(g));
        MOVE PROPERTY(minAge(g));
        MOVE PROPERTY(available(g));
    }
    NEW geClub {
        horizontal = FALSE;
        MOVE PROPERTY(publisher(g));
        MOVE PROPERTY(owner(g));
        MOVE PROPERTY(gameEditOwnerHint());
    }
    NEW geMech {
        horizontal = FALSE;
        fill = 1;
        // hasMechanic отображается в GRID объекта m — переносим контейнер таблицы, не PROPERTY.
        MOVE BOX(m);
    }
}

openGameCard 'Открыть карточку игры' (BoardGame g) {
    SHOW gameDetail OBJECTS g = g;
}

editGameFromCard 'Редактировать игру' (BoardGame g) {
    SHOW gameEdit OBJECTS g = g;
}

EXTEND FORM gameDetail
    PROPERTIES(g) NEWSESSION editGameFromCard SHOWIF canEdit()
;

// --- Подбор по названию ---

// Подбор опорной игры: сначала список с фильтром по названию, затем карточка или рекомендации.
FORM similarGamesFinder 'Найти похожую игру'
    PROPERTIES()
        READONLY similarFinderStep1 PANEL, similarFinderStep2 PANEL, similarFinderStep3 PANEL, similarFinderSearchHint PANEL
    OBJECTS g = BoardGame
    PROPERTIES(g) READONLY name, genre, playerRange, isAvailable
    PROPERTIES(g) NEWSESSION getRecommendations, openGameCard
    USERFILTERS name(g), genre(g), isAvailable(g)
    ORDERS name(g)
;

DESIGN similarGamesFinder {
    NEW similarFinderIntro FIRST {
        horizontal = FALSE;
        fill = 1;
        MOVE PROPERTY(similarFinderStep1());
        MOVE PROPERTY(similarFinderStep2());
        MOVE PROPERTY(similarFinderStep3());
        MOVE PROPERTY(similarFinderSearchHint());
    }
}

// --- Библиотека (каталог клуба: те же действия рекомендаций и карточки, что и в подборе похожих) ---

FORM gamesLibrary 'Библиотека настольных игр'
    PROPERTIES()
        READONLY gamesLibraryLead PANEL, gamesLibrarySubLead PANEL, gamesLibraryFiltersHint PANEL
    OBJECTS
        playersAtTable 'Сколько играет человек' = INTEGER PANEL,
        g = BoardGame
    PROPERTIES(playersAtTable) VALUE
    PROPERTIES(g) READONLY name, genre, playerRange, durationMinutes, isAvailable
    PROPERTIES(g) NEWSESSION getRecommendations, openGameCard
    FILTERS libraryMatchesPlayerCountFilter(g, playersAtTable)
    USERFILTERS name(g), genre(g), isAvailable(g)
    ORDERS name(g)
;

DESIGN gamesLibrary {
    NEW gamesLibIntro FIRST {
        horizontal = FALSE;
        fill = 1;
        MOVE PROPERTY(gamesLibraryLead());
        MOVE PROPERTY(gamesLibrarySubLead());
        MOVE PROPERTY(gamesLibraryFiltersHint());
    }
}

// --- Главная участника: только после объявления форм similarGamesFinder / gamesLibrary и действий getRecommendations, openGameCard ---

openSimilarGamesFlow 'Найти похожую игру' () {
    SHOW similarGamesFinder;
}

openGamesLibraryFlow 'Библиотека настольных игр' () {
    SHOW gamesLibrary;
}

FORM userHomeHub 'Главная'
    PROPERTIES()
        READONLY hubTitle PANEL, hubSubtitle PANEL
    PROPERTIES()
        // Кнопки: локальное имя на форме + вызов глобального действия (как welcomeLogin на приветствии).
        hubOpenSimilar 'Найти похожую игру' = openSimilarGamesFlow[]
    PROPERTIES()
        READONLY hubHintSimilar PANEL
    PROPERTIES()
        hubOpenLibrary 'Библиотека настольных игр' = openGamesLibraryFlow[]
    PROPERTIES()
        READONLY hubHintLibrary PANEL
;

DESIGN userHomeHub {
    NEW hubIntro FIRST {
        horizontal = FALSE;
        fill = 1;
        MOVE PROPERTY(hubTitle());
        MOVE PROPERTY(hubSubtitle());
    }
    NEW hubActions {
        horizontal = TRUE;
        NEW hubColSimilar {
            horizontal = FALSE;
            MOVE PROPERTY(hubOpenSimilar);
            MOVE PROPERTY(hubHintSimilar());
        }
        NEW hubColLibrary {
            horizontal = FALSE;
            MOVE PROPERTY(hubOpenLibrary);
            MOVE PROPERTY(hubHintLibrary());
        }
    }
}

// --- Тексты административного контура (только UX, без бизнес-логики) ---

adminGamesCatalogLead ' ' () =
    'Полный каталог игр клуба. «Создать» — новая игра, «Изменить» — карточка со всеми полями и картинкой.' CHARWIDTH 95;

adminGamesCatalogSubLead ' ' () =
    'Ручные похожие для рекомендаций настраиваются отдельно в «Похожие игры для рекомендаций». Жанры, издательства и владельцы экземпляров — в разделе «Справочники».' CHARWIDTH 95;

manualSimilarLead1 ' ' () =
    'Выберите игру слева. В таблице отметьте, на какие другие игры из каталога она похожа — участникам это усилит подсказки «найти похожую».' CHARWIDTH 95;

manualSimilarLead2 ' ' () =
    'Снятая галочка убирает связь. Игра не может быть похожа сама на себя.' CHARWIDTH 95;

clubUsersLead1 ' ' () =
    'Здесь все зарегистрированные участники. Колонка «Администратор» показывает, кто может править каталог и назначать роли.' CHARWIDTH 95;

clubUsersLead2 ' ' () =
    'Первого администратора сервер может выдать автоматически по email из настройки boardgame.initialAdminEmail; остальных назначаете здесь. Нельзя снять права с себя и с последнего администратора.' CHARWIDTH 95;

clubUsersLead3 ' ' () =
    'На этом экране можно назначить администратора или снять права. С себя снять нельзя; у единственного администратора в системе — тоже (сначала назначьте другого).' CHARWIDTH 95;

// --- Справочники: только администратор ---

FORM genresView 'Справочник жанров'
    OBJECTS gen = Genre
    PROPERTIES(gen) READONLY name
    LIST Genre OBJECT gen
;

FORM publishersView 'Справочник издательств'
    OBJECTS p = Publisher
    PROPERTIES(p) READONLY name, website, country
    LIST Publisher OBJECT p
;

FORM ownersView 'Владельцы экземпляров (справочник)'
    OBJECTS o = Owner
    PROPERTIES(o) READONLY name, contacts
    LIST Owner OBJECT o
;

// --- Администрирование: игры ---

FORM gamesAdmin 'Игры клуба'
    PROPERTIES()
        READONLY adminGamesCatalogLead PANEL, adminGamesCatalogSubLead PANEL
    OBJECTS g = BoardGame
    PROPERTIES(g) READONLY name, genre, playerRange, durationMinutes, minAge, publisher, available
    PROPERTIES(g) NEWSESSION NEW, EDIT, DELETE SHOWIF canEdit()
    USERFILTERS name(g), genre(g)
    EDIT BoardGame OBJECT g
;

DESIGN gamesAdmin {
    NEW gamesAdminIntro FIRST {
        horizontal = FALSE;
        fill = 1;
        MOVE PROPERTY(adminGamesCatalogLead());
        MOVE PROPERTY(adminGamesCatalogSubLead());
    }
}

FORM manualSimilarAdmin 'Похожие игры для рекомендаций'
    PROPERTIES()
        READONLY manualSimilarLead1 PANEL, manualSimilarLead2 PANEL
    OBJECTS
        src = BoardGame PANEL,
        cand = BoardGame
    PROPERTIES(src) READONLY name
    PROPERTIES(src, cand) manualSimilarTo
    FILTERS NOT (src = cand)
    EDIT BoardGame OBJECT src
;

DESIGN manualSimilarAdmin {
    NEW manualSimilarIntro FIRST {
        horizontal = FALSE;
        fill = 1;
        MOVE PROPERTY(manualSimilarLead1());
        MOVE PROPERTY(manualSimilarLead2());
    }
}

FORM gameMechanics 'Механики в игре'
    OBJECTS
        g = BoardGame PANEL,
        m = Mechanic
    PROPERTIES(g, m) hasMechanic
    EDIT BoardGame OBJECT g
;

// --- Администрирование: участники ---

FORM clubUsersAdmin 'Участники и роли'
    PROPERTIES()
        READONLY clubUsersLead1 PANEL, clubUsersLead2 PANEL, clubUsersLead3 PANEL
    OBJECTS u = CustomUser
    PROPERTIES(u) READONLY login, email, name, clubUserIsAdmin
    PROPERTIES(u) NEWSESSION setUserIsAdmin SHOWIF isAdmin() AND NOT clubUserIsAdmin(u)
    PROPERTIES(u) NEWSESSION clearUserIsAdmin SHOWIF isAdmin() AND clubUserIsAdmin(u)
    LIST CustomUser OBJECT u
;

DESIGN clubUsersAdmin {
    NEW clubUsersIntro FIRST {
        horizontal = FALSE;
        fill = 1;
        MOVE PROPERTY(clubUsersLead1());
        MOVE PROPERTY(clubUsersLead2());
        MOVE PROPERTY(clubUsersLead3());
    }
}

// --- Администрирование: справочники ---

FORM genreEdit 'Редактирование жанра'
    OBJECTS gen = Genre PANEL
    PROPERTIES(gen) name
    EDIT Genre OBJECT gen
;

FORM genresAdmin 'Жанры'
    OBJECTS gen = Genre
    PROPERTIES(gen) READONLY name
    PROPERTIES(gen) NEWSESSION NEW, EDIT, DELETE SHOWIF canEdit()
    EDIT Genre OBJECT gen
;

FORM publisherEdit 'Редактирование издательства'
    OBJECTS p = Publisher PANEL
    PROPERTIES(p) name, website, country
    EDIT Publisher OBJECT p
;

FORM publishersAdmin 'Издательства'
    OBJECTS p = Publisher
    PROPERTIES(p) READONLY name, website, country
    PROPERTIES(p) NEWSESSION NEW, EDIT, DELETE SHOWIF canEdit()
    EDIT Publisher OBJECT p
;

FORM ownerEdit 'Редактирование владельца экземпляра'
    OBJECTS o = Owner PANEL
    PROPERTIES(o) name, contacts
    EDIT Owner OBJECT o
;

FORM ownersAdmin 'Владельцы экземпляров'
    OBJECTS o = Owner
    PROPERTIES(o) READONLY name, contacts
    PROPERTIES(o) NEWSESSION NEW, EDIT, DELETE SHOWIF canEdit()
    EDIT Owner OBJECT o
;

FORM mechanicEdit 'Редактирование механики'
    OBJECTS m = Mechanic PANEL
    PROPERTIES(m) name
    EDIT Mechanic OBJECT m
;

FORM mechanicsAdmin 'Механики'
    OBJECTS m = Mechanic
    PROPERTIES(m) READONLY name
    PROPERTIES(m) NEWSESSION NEW, EDIT, DELETE SHOWIF canEdit()
    EDIT Mechanic OBJECT m
;

// --- Навигатор ---
// Оба корневых экрана с FIRST: платформа открывает первый подходящий по порядку объявления.
// Сначала главная участника (видна после входа), затем приветствие (гость) — иначе при скрытом
// welcomeLanding не остаётся стартовой формы и экран остаётся пустым.

NAVIGATOR {
    NEW userHomeHub FIRST SHOWIF NOT isClubGuest() AND (currentUser() IS CustomUser);
    NEW welcomeLanding FIRST SHOWIF isClubGuest();
    NEW FOLDER administration 'Администрирование' SHOWIF isAdmin() {
        NEW FOLDER adminCatalog 'Каталог игр' {
            NEW gamesAdmin;
            NEW manualSimilarAdmin;
        }
        NEW FOLDER adminMembers 'Участники и роли' {
            NEW clubUsersAdmin;
        }
        NEW FOLDER adminRef 'Справочники' {
            NEW genresAdmin;
            NEW publishersAdmin;
            NEW ownersAdmin;
            NEW mechanicsAdmin;
        }
        NEW FOLDER adminDemo 'Демо и проверка' {
            NEW ACTION loadExampleData;
        }
        NEW FOLDER referencesReadonly 'Справочники: только просмотр' {
            NEW genresView;
            NEW publishersView;
            NEW ownersView;
        }
    }
}
