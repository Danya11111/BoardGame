<?xml version="1.0" encoding="UTF-8"?>
<!-- Шаблон контекста Tomcat: host/port подставляются entrypoint-скриптом (см. docker-entrypoint-web.sh). -->
<Context docBase="/opt/lsfusion/lsfusion-client.war">
  <!--
    В WAR заданы context-param host=localhost (web.xml). У Tomcat по умолчанию override=true,
    из‑за чего web.xml перетирает значения из этого файла → web ходит на localhost:7652 внутри
    контейнера и получает Connection refused. override=false — наш хост/порт неизменны.
  -->
  <Parameter name="host" value="@LOGICS_HOST@" override="false"/>
  <Parameter name="port" value="@LOGICS_PORT@" override="false"/>
  <Parameter name="exportName" value="default" override="false"/>
</Context>
