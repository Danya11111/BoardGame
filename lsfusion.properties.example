# Скопируйте в lsfusion.properties (в корень проекта) и задайте db.password.
# Не коммитьте lsfusion.properties — файл в .gitignore.
#
# ВАЖНО: BusinessLogicsBootstrap ищет конфиг как /lsfusion.properties (на Windows это C:\lsfusion.properties),
# а не файл в папке проекта. Поэтому для локального запуска используйте .\run.ps1, run.bat или run.sh —
# они читают ЭТОТ файл и передают параметры в JVM через -Ddb.* .
#
db.server=localhost:5432
db.name=boardgame
db.user=postgres
db.password=CHANGE_ME

# Необязательно — если порты заняты другим процессом lsFusion:
# rmi.port=7652
# http.port=7651

# Email первого администратора: при регистрации или смене email пользователь с этим адресом (без учёта регистра)
# получит роль admin. Пробрасывается в JVM как -Dboardgame.initialAdminEmail (run.ps1 / run.sh / Docker).
# boardgame.initialAdminEmail=admin@example.com

# Полный URL страницы регистрации в браузере (веб-клиент lsFusion). Если задан — кнопка «Зарегистрироваться» на приветствии откроет его.
# Пример: http://localhost:8080/lsfusion/registration
# boardgame.registrationUrl=http://localhost:8080/lsfusion/registration
