# Пример переменных для docker compose (скопируйте в .env при необходимости).
# Сборка logics требует lib/lsfusion-server-6.1.jar (см. README, download-server.ps1).

POSTGRES_PASSWORD=boardgame_dev
# Пароль задаётся только при первом создании тома postgres_data.
# Если после смены POSTGRES_PASSWORD логика падает с «password authentication failed»,
# либо верните прежний пароль, либо пересоздайте том: docker compose down -v (данные БД удалятся).

# Режим разработки lsFusion: анонимный вход с правами администратора (только для быстрой отладки UI).
# Для сценария «сначала приветствие, затем логин» выставьте false и пересоздайте volume БД при смене.
LSFUSION_DEVMODE=true

# Опционально: email для автоназначения роли admin (см. BoardGameAuth.lsf).
# BOARDGAME_INITIAL_ADMIN_EMAIL=

# Опционально: полный URL регистрации для кнопки на приветствии.
# BOARDGAME_REGISTRATION_URL=

# Куда контейнер web обращается по RMI за сервером логики:
# — все сервисы в compose: logics (по умолчанию)
# — web в Docker, logics на хосте (Windows/Mac): host.docker.internal
# — оба на одной машине без compose-сети: редко; тогда localhost с точки зрения процесса Tomcat
LSFUSION_LOGICS_HOST=logics
LSFUSION_LOGICS_PORT=7652
