# Copy to .env next to docker-compose.yml:
#   copy .env.example .env
# Then edit POSTGRES_PASSWORD.

POSTGRES_PASSWORD=change_me_strong_password

# lsFusion dev mode: anonymous UI/API access as admin (recommended for local demo)
LSFUSION_DEVMODE=true

# Optional: set admin password on FIRST start with an empty DB (requires docker compose down -v to reapply)
LSFUSION_INITIAL_ADMIN_PASSWORD=admin123

# Optional: email of the bootstrap admin (gets role admin when registering with this email)
BOARDGAME_INITIAL_ADMIN_EMAIL=admin@example.com

# Optional: full URL opened by «Зарегистрироваться» on welcome (e.g. web client registration page)
# BOARDGAME_REGISTRATION_URL=http://localhost:8080/lsfusion/registration
